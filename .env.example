# Copy to .env and fill in values — never commit .env to git

# Binance Testnet keys (https://testnet.binance.vision)
BINANCE_API_KEY=your_testnet_api_key
BINANCE_API_SECRET=your_testnet_api_secret

# FreqUI / REST API credentials
FREQTRADE_API_USER=admin
FREQTRADE_API_PASS=changeme
FREQTRADE_JWT_SECRET=change_this_to_a_long_random_string

# Optional Telegram bot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
