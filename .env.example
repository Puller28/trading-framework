# Railway reads this file to suggest variables when adding a new service.
# Set real values in the Railway Variables tab — never commit actual secrets.

# Which strategy this service runs (Strategy01 through Strategy05)
STRATEGY=Strategy01

# Bybit Testnet keys (https://testnet.bybit.com)
BYBIT_API_KEY=your_testnet_api_key
BYBIT_API_SECRET=your_testnet_api_secret

# FreqUI login credentials
FREQTRADE__API_SERVER__USERNAME=admin
FREQTRADE__API_SERVER__PASSWORD=changeme
FREQTRADE__API_SERVER__JWT_SECRET_KEY=change_this_to_a_long_random_string

# Optional Telegram notifications
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
